{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "testflight": {
      "extends": "production",
      "distribution": "store"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "gulbeyazvatanseverozturk@gmail.com",
        "ascAppId": "6761783988",
        "appleTeamId": "ZZP9DF22BB"
      }
    },
    "testflight": {
      "extends": "production"
    }
  }
}
