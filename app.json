{
  "expo": {
    "name": "Omnifolio",
    "slug": "omnifolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "omnifolio",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "backgroundColor": "#0B1220",
      "barStyle": "light-content",
      "translucent": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gulbeyazozturk.omnifolio",
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Omnifolio portföy verilerinize yalnızca sizin erişebilmeniz için Face ID kullanılır.",
        "UIStatusBarStyle": "UIStatusBarStyleLightContent"
      }
    },
    "newArchEnabled": true,
    "android": {
      "package": "com.gulbeyazozturk.omnifolio",
      "adaptiveIcon": {
        "backgroundColor": "#0B1220",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-notifications",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1220",
          "dark": {
            "backgroundColor": "#0B1220"
          }
        }
      ],
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Omnifolio portföy verilerinize yalnızca sizin erişebilmeniz için Face ID kullanılır."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "githubUsername": "gulbeyazozturk",
      "githubRepoSlug": "portfoy-takip",
      "eas": {
        "projectId": "54ffabab-2eae-4b68-8a7e-99e3bb5270f0"
      }
    },
    "owner": "gulbeyazozturk"
  }
}
