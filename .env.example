# Supabase - https://supabase.com/dashboard projenizden alın
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Opsiyonel — yalnızca yerel geliştirme (Expo Go). Supabase, exp://192.168.x.x içeren redirect’leri reddedebilir.
# `npx expo start --tunnel` sonrası Metro’daki tam deep link’i kopyalayın; Supabase → Redirect URLs’e de aynı satırı ekleyin.
# Boş bırakırsanız Linking.createURL('oauth-callback') kullanılır.
# EXPO_PUBLIC_OAUTH_REDIRECT_URL=exp://....../--/oauth-callback
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=exp://....../--/reset-password

# Opsiyonel: Sync script'leri için (sync-crypto, sync-bist vb.). Tarayıcıda kullanmayın.
SUPABASE_SERVICE_ROLE_KEY=

# Günlük admin raporu — Supabase Edge + Resend (npm run setup:daily-report)
# RESEND_API_KEY=re_xxxxxxxx
# DAILY_REPORT_TO=hasimozturk@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password-here
# SMTP_FROM=you@gmail.com
